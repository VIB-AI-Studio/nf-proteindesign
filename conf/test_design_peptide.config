/*
========================================================================================
    Nextflow config file for testing DESIGN mode - Peptide
========================================================================================
    Tests the design mode using pre-made Boltzgen YAML file for peptide with 2VSM as target.
    
    This profile tests:
    - Peptide binder design
    - Single design with num_designs=5 and budget=2
    
    Use as follows:
        nextflow run main.nf -profile test_design_peptide,docker

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Test profile - Design Mode (Peptide)'
    config_profile_description = 'Test dataset for design mode using 2VSM with pre-made peptide YAML spec'

    // Input data - design mode with 2VSM peptide
    input       = "${projectDir}/assets/test_data/samplesheet_design_peptide.csv"
    mode        = 'design'

    // Test-specific parameter overrides (all analysis modules are enabled by default)
    mpnn_num_seq_per_target    = 2      // Reduced from default 8 for faster testing
    boltz2_num_recycling       = 1      // Reduced for faster testing
    boltz2_num_diffusion       = 1      // Reduced for faster testing
    run_foldseek               = false  // Disabled - requires external database

    boltz2_predict_affinity    = false  // Peptides treated as proteins by Boltz-2
    boltz2_use_msa             = true   // Enable MSA server for peptides without MSA files

    // Output
    outdir      = './results_test_design_peptide'
}
