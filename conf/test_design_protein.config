/*
========================================================================================
    Nextflow config file for testing DESIGN mode - Protein
========================================================================================
    Tests the design mode using pre-made Boltzgen YAML file for protein with 2VSM as target.
    
    This profile tests:
    - Protein binder design
    - Single design with num_designs=5 and budget=2
    
    Use as follows:
        nextflow run main.nf -profile test_design_protein,docker

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Test profile - Design Mode (Protein)'
    config_profile_description = 'Test dataset for design mode using 2VSM with pre-made protein YAML spec'

    // Input data - design mode with 2VSM protein
    input       = "${projectDir}/assets/test_data/samplesheet_design_protein.csv"
    mode        = 'design'
    
    // Enable all metrics modules for comprehensive testing
    run_proteinmpnn            = true
    mpnn_num_seq_per_target    = 2     // Reduced from default 8 for faster testing
    run_boltz2_refold          = true
    boltz2_predict_affinity    = false // Affinity only supported for ligands, not proteins
    boltz2_use_msa             = false  // Required when input YAML has no MSAs
    boltz2_num_recycling       = 1
    boltz2_num_diffusion       = 1
    run_ipsae                  = true
    run_prodigy                = true
    run_foldseek               = true
    run_consolidation          = true
    
    // Output
    outdir      = './results_test_design_protein'
}
